    "pinia": "^2.2.0",
    "postmark": "^4.0.4",
    "vue": "^3.4.14",
    "vue-router": "^4.2.5"
  },
  "meteor": {
    "modern": true,
    "modules": [
      "src/client/startup/main.html",
      "src/client/startup/main.css"
    ],
    "mainModule": {
      "client": "src/client/startup/main.js",
      "server": "src/server/startup/main.js"
    },
    "testModule": "tests/main.js"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@meteorjs/rspack": "^1.0.0",
    "@rsdoctor/rspack-plugin": "^1.2.3",
